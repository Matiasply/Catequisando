// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id_usuario Int     @id @default(autoincrement())
  nome       String
  senha      String
  role       String

  progressos Progresso_Usuario[]
}

model Secoes {
  id_secao   Int     @id @default(autoincrement())
  nome_secao String

  modulos Modulos[]
}

model Modulos {
  id_modulo  Int    @id @default(autoincrement())
  nome_modulo String

  id_secao Int
  secao    Secoes @relation(fields: [id_secao], references: [id_secao])

  submodulos Submodulos[]
}

model Submodulos {
  id_submodulo  Int    @id @default(autoincrement())
  nome_submodulo String
  ordem          Int

  id_modulo Int
  modulo    Modulos @relation(fields: [id_modulo], references: [id_modulo])

  aulas Aula[]
}

model Aula {
  id_aula Int @id @default(autoincrement())

  id_submodulo Int
  submodulo    Submodulos @relation(fields: [id_submodulo], references: [id_submodulo])

  url_video String?
  url_audio String?
  url_imagem String?

  textos Texto[]
  quizzes Quiz_aula[]
  perguntas Perguntas[]
  progressos Progresso_Usuario[]
}

model Texto {
  id_texto    Int    @id @default(autoincrement())
  titulo      String
  corpo       String
  referencias String?

  id_aula Int
  aula    Aula @relation(fields: [id_aula], references: [id_aula])
}

model Quiz_aula {
  id Int @id @default(autoincrement())

  id_aula Int
  aula    Aula @relation(fields: [id_aula], references: [id_aula])

  perguntas Perguntas[]
}

model Perguntas {
  id_pergunta Int    @id @default(autoincrement())
  dificuldade String
  enunciado   String

  id_quiz Int?
  quiz    Quiz_aula? @relation(fields: [id_quiz], references: [id])

  id_aula Int?
  aula    Aula? @relation(fields: [id_aula], references: [id_aula])

  alternativas Alternativas[]
  temas Pergunta_tema[]
}

model Alternativas {
  id_alternativa Int    @id @default(autoincrement())
  enunciado      String
  certa          Boolean
  explicacao     String?

  id_pergunta Int
  pergunta    Perguntas @relation(fields: [id_pergunta], references: [id_pergunta])
}

model Temas {
  id_tema Int    @id @default(autoincrement())
  tema    String

  perguntas Pergunta_tema[]
}

model Pergunta_tema {
  id_pergunta Int
  id_tema     Int

  pergunta Perguntas @relation(fields: [id_pergunta], references: [id_pergunta])
  tema     Temas     @relation(fields: [id_tema], references: [id_tema])

  @@id([id_pergunta, id_tema]) // chave composta
}

model Progresso_Usuario {
  id Int @id @default(autoincrement())

  id_usuario Int
  usuario    Usuario @relation(fields: [id_usuario], references: [id_usuario])

  id_aula Int
  aula    Aula @relation(fields: [id_aula], references: [id_aula])

  porcentagem    Float
  concluido      Boolean
  ultima_interacao DateTime?
  data_conclusao DateTime?
}
